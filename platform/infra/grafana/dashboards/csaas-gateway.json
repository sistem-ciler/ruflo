{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "csaas_gateway_requests_total",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "csaas_gateway_errors_total",
          "legendFormat": "Total 5xx Errors",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "csaas_gateway_uptime_seconds",
          "legendFormat": "Uptime (s)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "csaas_gateway_memory_bytes{type=\"heap_used\"}",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "csaas_gateway_memory_bytes{type=\"rss\"}",
          "legendFormat": "RSS",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Error Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "csaas_gateway_errors_total / csaas_gateway_requests_total",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["csaas", "gateway"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CSaaS Gateway",
  "uid": "csaas-gateway",
  "version": 1
}
