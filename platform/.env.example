# CSaaS Platform — Environment Variables
# Copy to .env and fill in production values

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=csaas
POSTGRES_PASSWORD=change-me
POSTGRES_DB=csaas

# ─── Redis ───────────────────────────────────────────────
# No auth in dev; set password for production

# ─── RabbitMQ ────────────────────────────────────────────
RABBITMQ_USER=csaas
RABBITMQ_PASSWORD=change-me

# ─── MinIO (S3-compatible Object Storage) ────────────────
MINIO_USER=csaas
MINIO_PASSWORD=change-me-min-8-chars

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=generate-a-64-char-random-string-here-for-production

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ─── Grafana ─────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── LLM — OpenRouter (cloud) ────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── LLM — Ollama (local) ────────────────────────────────
OLLAMA_MODEL=llama3

# ─── LLM Provider Preference ─────────────────────────────
# "auto" = uses OpenRouter if API key is set, else Ollama
# "openrouter" = force cloud LLM
# "ollama" = force local LLM
LLM_PROVIDER=auto
