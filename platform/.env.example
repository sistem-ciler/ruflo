# CSaaS Platform — Environment Variables
# Copy to .env and fill in production values

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=csaas
POSTGRES_PASSWORD=change-me
POSTGRES_DB=csaas

# ─── Redis ───────────────────────────────────────────────
# No auth in dev; set password for production

# ─── RabbitMQ ────────────────────────────────────────────
RABBITMQ_USER=csaas
RABBITMQ_PASSWORD=change-me

# ─── MinIO (S3-compatible Object Storage) ────────────────
MINIO_USER=csaas
MINIO_PASSWORD=change-me-min-8-chars

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=generate-a-64-char-random-string-here-for-production

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ─── Grafana ─────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── OpenRouter (LLM fallback) ───────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
