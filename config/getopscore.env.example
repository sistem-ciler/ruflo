# ================================================================
# getopscore.com — Environment Configuration
# Copy to .env and fill in values. Never commit the real .env.
# ================================================================

# --- Cloudflare Tunnel ---
TUNNEL_TOKEN=           # From: cloudflared tunnel token getopscore

# --- Hetzner Cloud (VM Lifecycle Engine) ---
HETZNER_API_TOKEN=      # Hetzner Cloud API token (read/write)
HETZNER_DATACENTER=fsn1 # fsn1=Frankfurt, nbg1=Nuremberg, hel1=Helsinki, ash=Ashburn
HETZNER_SERVER_TYPE=cx22 # cx22=2vCPU/4GB (~€4/mo), cx32=4vCPU/8GB (~€8/mo)
HETZNER_SSH_KEY_NAME=   # SSH key name as registered in Hetzner Cloud project
HETZNER_PRIVATE_NETWORK_ID= # Private network ID (optional, for VM isolation)
HETZNER_MAX_MONTHLY_EUR=50  # Hard cost ceiling — engine won't exceed this

# --- VM Decision Engine Thresholds ---
VM_QUEUE_DEPTH_THRESHOLD=10   # Create VM when pending task queue exceeds this
VM_COMPLEXITY_THRESHOLD=0.70  # Create VM when task complexity score > 70%
VM_SLA_BREACH_SECONDS=300     # Create VM if projected completion > 5 min past SLA
VM_WARM_POOL_SIZE=0           # 0=on-demand, N=keep N VMs always warm
VM_IDLE_TIMEOUT_SECONDS=600   # Destroy VM after 10 min with no active tasks

# --- AI Provider Keys (at least one required) ---
ANTHROPIC_API_KEY=      # sk-ant-...
OPENAI_API_KEY=         # sk-...
GOOGLE_API_KEY=         # For Gemini grounded search

# --- MCP Bridge Tool Groups ---
MCP_GROUP_INTELLIGENCE=true
MCP_GROUP_AGENTS=true
MCP_GROUP_MEMORY=true
MCP_GROUP_DEVTOOLS=true
MCP_GROUP_SECURITY=false
MCP_GROUP_BROWSER=false
MCP_GROUP_NEURAL=false
MCP_GROUP_VM=true           # Enable Hetzner VM lifecycle MCP tools

# --- Branding ---
BRAND_NAME=OpsCore
BRAND_DESCRIPTION=Autonomous AI Agent Orchestration Platform

# --- Database ---
MONGODB_DB_NAME=opscore-db

# --- Runtime ---
NODE_ENV=production
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
